PORT=3000
NODE_ENV=development

# Optional persistent data directory. It must survive deployments/restarts.
FETCHSTORY_DATA_DIR=./data

# Optional explicit SQLite file path. Overrides the default data/users.sqlite.
# FETCHSTORY_DB_PATH=./data/users.sqlite

# Used only when the database has no users and the first admin is created.
FETCHSTORY_ADMIN_USERNAME=admin
FETCHSTORY_ADMIN_PASSWORD=change-this-password
